---
interface Props {
  title: string;
  description: string;
  canonical?: string;
  schema?: object | object[];
  ogImage?: string;
}

const { title, description, canonical, schema, ogImage } = Astro.props;
const canonicalURL = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
const ogImageURL = ogImage
  ? new URL(ogImage, Astro.site).toString()
  : new URL('/images/og-default.webp', Astro.site).toString();
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL} />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />

<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:type" content="website" />
<meta property="og:image" content={ogImageURL} />
<meta property="og:locale" content="en_CA" />
<meta property="og:site_name" content="Ottawa Mattress" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageURL} />

{schema && (
  <script type="application/ld+json" set:html={JSON.stringify(Array.isArray(schema) ? schema : schema)} />
)}
