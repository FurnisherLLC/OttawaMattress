---
import SEOHead from '../components/SEOHead.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  schema?: object | object[];
  ogImage?: string;
}

const { title, description, canonical, schema, ogImage } = Astro.props;
---

<!doctype html>
<html lang="en-CA">
  <head>
    <SEOHead
      title={title}
      description={description}
      canonical={canonical}
      schema={schema}
      ogImage={ogImage}
    />
  </head>
  <body>
    <Nav />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>
