---
import Base from '../layouts/Base.astro';
import business from '../data/business.json';

const variants = [
  {
    id: 'soft',
    name: 'Beaumont Soft',
    firmness: 'Soft',
    ticking: 'Red ticking',
    tickingColor: '#B5433B',
    img: '/images/mattresses/beaumont-soft.webp',
    desc: 'Soft density transition layer. The comfort layer and soft latex work together to let shoulders and hips sink in just enough to keep the spine neutral. No memory foam lag.',
    ideal: ['Side sleepers', 'Joint sensitivity', 'Plush feel'],
  },
  {
    id: 'medium',
    name: 'Beaumont Medium',
    firmness: 'Medium',
    ticking: 'Blue ticking',
    tickingColor: '#2B4B82',
    img: '/images/mattresses/beaumont-medium.webp',
    desc: 'Medium density transition layer. The most versatile build we offer. Handles back, side, and combination sleeping well. The starting point for couples who can agree on something.',
    ideal: ['Back sleepers', 'Combination sleepers', 'Couples with similar needs'],
  },
  {
    id: 'firm',
    name: 'Beaumont Firm',
    firmness: 'Firm',
    ticking: 'Green ticking',
    tickingColor: '#4E7260',
    img: '/images/mattresses/beaumont-firm.webp',
    desc: 'Firm density transition layer. Strong lumbar support with the responsive, springy feel that only real latex provides. Holds the hips level for stomach sleepers.',
    ideal: ['Stomach sleepers', 'Back sleepers', 'Firm feel preference'],
  },
  {
    id: 'extra-firm',
    name: 'Beaumont Extra Firm',
    firmness: 'Extra Firm',
    ticking: 'Black ticking',
    tickingColor: '#1A1A1A',
    img: '/images/mattresses/beaumont-extra-firm.webp',
    desc: 'Extra firm density transition layer. Maximum support with minimal give. Works standalone for those who need it, or as a dense structural foundation beneath a comfort layer.',
    ideal: ['Stomach sleepers', 'Heavyweight support', 'Minimal give preference'],
  },
];

const specialty = [
  {
    id: 'rv',
    name: 'RV Mattresses',
    img: '/images/specialty/rv.webp',
    desc: 'No two RVs share the same sleeping space. We build to your exact measurements in any configuration. Natural latex is lighter than coil and holds its shape without a box spring.',
  },
  {
    id: 'boat',
    name: 'Boat & Marine Mattresses',
    img: '/images/specialty/boat.webp',
    desc: 'Berths, settees, and V-bunks are rarely rectangular. We build to a paper template or precise measurements. Natural latex resists moisture and holds its form under humid conditions.',
  },
  {
    id: 'custom-pillows',
    name: 'Custom Pillows',
    img: '/images/specialty/custom-pillows.webp',
    desc: 'Latex and cotton fill pillows in any dimension. Shredded latex for adjustable loft, solid core for consistent support. Made to match the mattress or stand alone.',
  },
  {
    id: 'custom-shapes',
    name: 'Custom Shapes & Sizes',
    img: '/images/specialty/heart.webp',
    desc: 'Antique frames, platform beds, unusual dimensions, non-standard shapes. If your size does not exist in a catalog, we build it. Bring measurements or a paper template.',
  },
];

const specs = [
  { label: 'Support layer', value: 'Natural latex (Talalay or Dunlop) or pocket coil innerspring, buyer\'s choice' },
  { label: 'Transition layer', value: 'Natural latex foam at your chosen density (Soft, Medium, Firm, or Extra Firm). Indicated by ticking colorway.' },
  { label: 'Comfort layer', value: 'Removable zipper pillow top in natural cotton, or additional latex foam' },
  { label: 'Ticking', value: 'French-stripe cotton in four colorways: Red (Soft), Blue (Medium), Green (Firm), Black (Extra Firm)' },
  { label: 'Construction', value: 'Bun-tufted top, flippable, zipper-removable pillow top' },
  { label: 'Standard thickness', value: '12" (custom thicknesses available on request)' },
  { label: 'Standard sizes', value: 'Twin, Double, Queen, King, or any custom dimension' },
  { label: 'Split options', value: 'Split Queen and Split King available, different firmness on each side' },
  { label: 'Lifespan', value: '25+ years with natural latex core' },
  { label: 'Price range', value: '$1,200 to $6,000 CAD depending on size and specification' },
];

const productSchema = {
  "@context": "https://schema.org",
  "@type": "ProductCollection",
  "name": "Beaumont Collection",
  "description": "Fully custom natural latex mattresses handcrafted by Mennonite artisans in South Ontario. Custom size, firmness, and construction. RV, boat, and specialty mattresses also available.",
  "brand": {
    "@type": "Brand",
    "name": "Ottawa Luxury Mattress"
  },
  "offers": {
    "@type": "AggregateOffer",
    "priceCurrency": "CAD",
    "lowPrice": "1200",
    "highPrice": "6000",
    "offerCount": "4"
  }
};
---

<Base
  title="Products | Custom Natural Latex Mattresses, RV, Boat & Specialty | Ottawa Mattress"
  description="Beaumont Collection custom latex mattresses, RV mattresses, boat mattresses, custom pillows and specialty builds. Four firmness levels, any size. Handcrafted in South Ontario. From $1,200 CAD."
  schema={productSchema}
>

  <section class="page-header">
    <div class="container">
      <p class="eyebrow">Beaumont Collection by Ottawa Luxury Mattress</p>
      <h1>Our Products</h1>
      <p>
        Custom natural latex mattresses, RV and boat builds, custom pillows, and specialty
        sizes. Every piece built to your exact specification by Mennonite craftspeople in South Ontario.
      </p>
    </div>
  </section>

  <!-- Anatomy of a mattress -->
  <section class="section section--chalkboard">
    <div class="container">
      <img
        src="/images/anatomy.webp"
        srcset="/images/anatomy.webp 1360w, /images/anatomy-2x.webp 2720w"
        sizes="(max-width: 1400px) 100vw, 1360px"
        alt="The Anatomy of an Artisan Mattress: diagram showing comfort, transition, and support layers with labels"
        width="1360"
        height="752"
        loading="lazy"
        class="anatomy-img"
      />
    </div>
  </section>

  <!-- Variants -->
  <section class="section section--white">
    <div class="container">
      <div class="section-header">
        <h2>Choose your firmness</h2>
        <p class="text-muted">The ticking colorway tells you the density of the transition layer. Everything else can be configured on top of that.</p>
      </div>
      <div class="variants">
        {variants.map((v, i) => (
          <div class="variant" id={v.id}>
            <div class="variant__image">
              <img src={v.img} alt={`${v.name}, ${v.ticking}`} width="540" height="540" loading={i < 2 ? 'eager' : 'lazy'} />
            </div>
            <div class="variant__body">
              <div class="variant__meta">
                <span class="variant__swatch" style={`background: ${v.tickingColor}`}></span>
                <span class="variant__ticking">{v.ticking}</span>
                <span class="variant__firmness">{v.firmness}</span>
              </div>
              <h2>{v.name}</h2>
              <p class="variant__desc">{v.desc}</p>
              <div class="variant__ideal">
                <h4>Ideal for</h4>
                <ul>
                  {v.ideal.map(item => <li>{item}</li>)}
                </ul>
              </div>
              <div class="variant__actions">
                <a href={`tel:${business.phone}`} class="btn btn-primary">Call to Order</a>
                <a href="/contact/" class="btn btn-outline">Visit the Showroom</a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Specialty products -->
  <section class="section section--cream-dark">
    <div class="container">
      <div class="section-header">
        <h2>What else we build</h2>
        <p class="text-muted">The same construction and materials, adapted to sleeping spaces that standard mattresses don't fit.</p>
      </div>
      <div class="specialty-grid">
        {specialty.map(s => (
          <div class="specialty-card">
            <div class="specialty-card__image">
              <img src={s.img} alt={s.name} width="400" height="400" loading="lazy" />
            </div>
            <div class="specialty-card__body">
              <h3>{s.name}</h3>
              <p>{s.desc}</p>
            </div>
          </div>
        ))}
      </div>
      <div class="specialty-cta">
        <p class="text-muted">Have something unusual? Call us and describe it. We've built for antique frames, camper vans, custom platform beds, hospital settings, and more.</p>
        <a href={`tel:${business.phone}`} class="btn btn-outline">{business.phoneFormatted}</a>
      </div>
    </div>
  </section>

  <!-- Full specs -->
  <section class="section section--white">
    <div class="container">
      <div class="specs-wrap">
        <div class="specs-header">
          <h2>Standard specifications</h2>
          <p class="text-muted">
            Every Beaumont is built from scratch. These are the defaults. Everything can be adjusted on request.
          </p>
        </div>
        <dl class="specs-table">
          {specs.map(s => (
            <div class="specs-row">
              <dt>{s.label}</dt>
              <dd>{s.value}</dd>
            </div>
          ))}
        </dl>
      </div>
    </div>
  </section>

  <!-- Craft section -->
  <section class="section section--navy">
    <div class="container craft">
      <div class="craft__text">
        <h2>Built by hand in South Ontario</h2>
        <p>
          Every Beaumont mattress is made by Mennonite craftspeople who have been building
          mattresses and furniture their entire lives. This is generational skill, not a
          factory floor or a warehouse assembly line.
        </p>
        <p>
          We specify every detail. They build it exactly. Then we deliver it to Ottawa.
        </p>
        <a href="/our-story/" class="btn btn-outline-cream">Our Story</a>
      </div>
      <div class="craft__callout">
        <blockquote>
          "Natural latex is the only mattress material that gets better with age rather than worse.
          It doesn't compress, doesn't off-gas, and doesn't need replacing every decade."
        </blockquote>
        <p class="craft__callout-attr">Ottawa Luxury Mattress</p>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="section section--white text-center">
    <div class="container" style="max-width: 620px;">
      <h2>Come in and feel the difference</h2>
      <p class="text-muted" style="margin: 1rem 0 2rem;">
        We have demonstration mattresses in the showroom. Lie on a few, ask questions,
        and we'll give you an exact quote before you commit to anything.
      </p>
      <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
        <a href={`tel:${business.phone}`} class="btn btn-primary">{business.phoneFormatted}</a>
        <a href="/contact/" class="btn btn-outline">Showroom Hours and Directions</a>
      </div>
    </div>
  </section>

</Base>

<style>
  .eyebrow {
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    opacity: 0.55;
    margin-bottom: 1rem;
    font-style: italic;
    color: var(--color-cream);
  }

  .page-header p { max-width: 640px; }

  .section-header {
    margin-bottom: 3rem;
  }

  .section-header h2 { margin-bottom: 0.5rem; }

  /* ── Anatomy ─────────────────────────────────── */
  .section--chalkboard {
    background: #1a1a1a;
    padding: 3rem 0;
  }

  .anatomy-img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 4px;
  }

  /* ── Variants ─────────────────────────────────── */
  .variants {
    display: flex;
    flex-direction: column;
    gap: 5rem;
  }

  .variant {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .variant:nth-child(even) .variant__image { order: 2; }
  .variant:nth-child(even) .variant__body  { order: 1; }

  .variant__image {
    border-radius: 4px;
    overflow: hidden;
    background: var(--color-white);
    border: 1px solid var(--color-border);
  }

  .variant__image img {
    width: 100%;
    height: auto;
    display: block;
    padding: 1.5rem;
    object-fit: contain;
  }

  .variant__meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .variant__swatch {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    display: inline-block;
    flex-shrink: 0;
  }

  .variant__ticking {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
  }

  .variant__firmness {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    border-left: 1px solid var(--color-border);
    padding-left: 0.75rem;
  }

  .variant h2 { margin-bottom: 1rem; }

  .variant__desc {
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
    font-size: 1rem;
    line-height: 1.7;
  }

  .variant__ideal { margin-bottom: 1.75rem; }

  .variant__ideal h4 {
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    margin-bottom: 0.5rem;
  }

  .variant__ideal ul {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .variant__ideal li {
    font-size: 0.82rem;
    background: var(--color-cream-dark);
    padding: 0.25rem 0.65rem;
    border-radius: 20px;
    color: var(--color-charcoal);
  }

  .variant__actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* ── Specialty grid ───────────────────────────── */
  .specialty-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }

  .specialty-card {
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .specialty-card__image {
    aspect-ratio: 1;
    overflow: hidden;
    background: var(--color-cream-dark);
  }

  .specialty-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .specialty-card:hover .specialty-card__image img {
    transform: scale(1.03);
  }

  .specialty-card__body {
    padding: 1.25rem;
  }

  .specialty-card__body h3 {
    font-size: 1rem;
    margin-bottom: 0.5rem;
  }

  .specialty-card__body p {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.65;
    margin: 0;
  }

  .specialty-cta {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .specialty-cta p {
    flex: 1;
    min-width: 240px;
    margin: 0;
    font-size: 0.9rem;
  }

  /* ── Specs ────────────────────────────────────── */
  .specs-wrap {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 4rem;
    align-items: start;
  }

  .specs-header h2 { margin-bottom: 0.75rem; }

  .specs-table {
    display: flex;
    flex-direction: column;
  }

  .specs-row {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 1rem;
    padding: 0.9rem 0;
    border-bottom: 1px solid var(--color-border);
    font-size: 0.9rem;
  }

  .specs-row:first-child { border-top: 1px solid var(--color-border); }

  dt {
    font-weight: 500;
    color: var(--color-charcoal);
  }

  dd {
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  /* ── Craft ────────────────────────────────────── */
  .craft {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .craft h2 { color: var(--color-cream); margin-bottom: 1rem; }
  .craft p { opacity: 0.82; line-height: 1.75; margin-bottom: 1.25rem; }

  .craft__callout {
    border-left: 2px solid rgba(247, 243, 236, 0.3);
    padding-left: 2rem;
  }

  .craft__callout blockquote {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.15rem;
    line-height: 1.65;
    opacity: 0.9;
    margin-bottom: 1rem;
  }

  .craft__callout-attr {
    font-size: 0.8rem;
    opacity: 0.5;
    margin: 0;
  }

  /* ── Responsive ───────────────────────────────── */
  @media (max-width: 860px) {
    .variant,
    .variant:nth-child(even) .variant__image,
    .variant:nth-child(even) .variant__body {
      grid-template-columns: 1fr;
      order: unset;
    }

    .variant { gap: 2rem; }

    .specs-wrap,
    .craft {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }

  @media (max-width: 560px) {
    .specialty-grid { grid-template-columns: 1fr; }
  }
</style>
