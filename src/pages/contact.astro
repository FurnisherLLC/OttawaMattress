---
import Base from '../layouts/Base.astro';
import business from '../data/business.json';

const metaDescription = `Ottawa Mattress showroom at ${business.address.full}. Mon–Fri 9–4:30, Sat 10–4, Sun 11–3. No appointment needed. Call ${business.phoneFormatted}.`;

const schema = {
  "@context": "https://schema.org",
  "@type": "FurnitureStore",
  "name": business.name,
  "url": business.url,
  "telephone": business.phone,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": business.address.streetAddress,
    "addressLocality": business.address.addressLocality,
    "addressRegion": business.address.addressRegion,
    "postalCode": business.address.postalCode,
    "addressCountry": business.address.addressCountry
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": business.geo.latitude,
    "longitude": business.geo.longitude
  },
  "openingHoursSpecification": [
    ...business.openingHours.map(h => ({
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": h.schemaDays,
      "opens": h.schemaOpens,
      "closes": h.schemaCloses
    }))
  ]
};
---

<Base
  title="Visit Us | Ottawa Mattress: Showroom in Nepean"
  description={metaDescription}
  schema={schema}
>

  <section class="page-header">
    <div class="container">
      <h1>Visit Our Showroom</h1>
      <p>No appointment needed during business hours. Come in, lie on a mattress, ask us anything.</p>
    </div>
  </section>

  <section class="section section--white">
    <div class="container contact-layout">

      <div class="contact-info">

        <div class="contact-phone">
          <a href={`tel:${business.phone}`} class="phone-link">
            {business.phoneFormatted}
          </a>
          <p>Call to ask questions, get a quote, or book a custom order.</p>
        </div>

        <div class="contact-block">
          <h3>Address</h3>
          <address>
            {business.address.streetAddress}<br />
            {business.address.addressLocality}, {business.address.addressRegion}<br />
            {business.address.postalCode}
          </address>
          <p class="address-note">
            Located in the Colonnade Business Park. Shared facility with Kessels Upholstery.
          </p>
        </div>

        <div class="contact-block">
          <h3>Hours</h3>
          <div class="hours-table">
            {business.openingHours.map(h => (
              <div class="hours-row">
                <span>{h.days}</span>
                <span>{h.opens} – {h.closes}</span>
              </div>
            ))}
          </div>
        </div>

        <div class="contact-block">
          <h3>What to expect</h3>
          <p>
            We keep demonstration mattresses in the showroom so you can actually feel
            the difference between firmness levels. We'll walk you through the construction,
            materials, and options, and we give you an exact quote before you commit to anything.
          </p>
        </div>

      </div>

      <div class="contact-map">
        <iframe
          title="Ottawa Mattress: 107 Colonnade Rd S #7, Nepean, ON"
          width="100%"
          height="100%"
          style="border:0; min-height: 420px; display: block;"
          loading="lazy"
          allowfullscreen
          referrerpolicy="no-referrer-when-downgrade"
          src="https://maps.google.com/maps?q=place_id:ChIJtZzL6ckHzkwRDZuUuGQrQ1E&output=embed&z=16"
        ></iframe>
      </div>

    </div>
  </section>

</Base>

<style>
  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: start;
  }

  .contact-phone {
    margin-bottom: 2.5rem;
  }

  .phone-link {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    color: var(--color-navy);
    display: block;
    margin-bottom: 0.5rem;
    transition: opacity 0.15s;
  }

  .phone-link:hover { opacity: 0.7; }

  .contact-phone p {
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }

  .contact-block {
    margin-bottom: 2rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .contact-block:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }

  .contact-block h3 {
    font-size: 0.72rem;
    font-family: var(--font-body);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }

  address {
    font-style: normal;
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-charcoal);
    margin-bottom: 0.5rem;
  }

  .address-note {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  .hours-table {
    display: flex;
    flex-direction: column;
  }

  .hours-row {
    display: flex;
    justify-content: space-between;
    max-width: 280px;
    padding: 0.35rem 0;
    font-size: 0.9rem;
    border-bottom: 1px solid var(--color-border);
    color: var(--color-text-muted);
  }

  .hours-row:first-child { border-top: 1px solid var(--color-border); }

  .contact-block p {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .contact-map {
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
    position: sticky;
    top: 90px;
  }

  @media (max-width: 820px) {
    .contact-layout {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .contact-map {
      position: static;
    }
  }
</style>
